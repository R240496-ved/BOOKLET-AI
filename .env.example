# BOOKLET AI — Environment Configuration
# Copy this to .env and fill in your values

# ── LLM MODE ──────────────────────────────────────────────
# Options: "api" (default) or "local" (requires Ollama running)
LLM_MODE=api

# ── API MODE (Groq / OpenAI-compatible) ──────────────────
LLM_API_KEY=your_groq_api_key_here
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_API_MODEL=llama-3.1-8b-instant

# ── LOCAL MODE (Ollama) ───────────────────────────────────
# Make sure Ollama is running: `ollama serve` and `ollama pull llama3.2:1b`
LLM_LOCAL_MODEL=llama3.2:1b
LLM_LOCAL_BASE=http://localhost:11434/v1

# ── RAG / EMBEDDINGS (HuggingFace) ────────────────────────
# Optional: Set your HF token if you hit rate limits
HF_TOKEN=